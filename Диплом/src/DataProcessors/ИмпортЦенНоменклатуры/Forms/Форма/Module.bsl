	ВхДанные.Вставить("Элемент2", Элемент2);
	ВхДанные.Вставить("Элемент3", Элемент3);
	ВхДанные.Вставить("Элемент4", Элемент4);
    Результат = Новый ТабличныйДокумент;
	Результат = ЗаполнитьНаСервереМО(ТаблицаФорма, ВхДанные, ТекДок);
	//Результат.Показать();
	
	Сообщить("Загрузка выполнена!");
КонецПроцедуры

